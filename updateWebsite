#!/bin/bash

# Define colors for a beautiful terminal output
BLUE='\033[1;34m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
ORANGE='\033[38;5;214m'
NC='\033[0m' # No Color (resets the text to normal)

echo -e "\n${ORANGE}🏎️  Step 1: Rendering Quarto website...${NC}"
# --quiet hides the pandoc spam, but will still show you if an error occurs!
quarto render --quiet

echo -e "${ORANGE}📦 Step 2: Staging files for Git...${NC}"
git add .

# Add a blank line for readability, then ask for the message
echo ""
read -p "💬 Enter your commit message: " commit_msg

# Safety check
if [ -z "$commit_msg" ]; then
  commit_msg="Routine portfolio update"
  echo -e "${YELLOW}⚠️  No message entered. Using default: '$commit_msg'${NC}"
fi

echo -e "\n${ORANGE}💾 Step 3: Committing changes...${NC}"
# -q hides the file insertion/deletion stats
git commit -q -m "$commit_msg"

echo -e "${ORANGE}🚀 Step 4: Pushing to GitHub...${NC}"
# -q hides the block compression and transfer stats
git push -q

echo -e "\n${GREEN}✅ Done! Your F1 portfolio is live.${NC}\n"
